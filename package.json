{
  "name": "bbs-app",
  "private": true,
  "scripts": {
    "dev:web": "turbo run dev --filter=web",
    "dev:admin": "turbo run dev --filter=admin",
    "dev:mobile": "turbo run start --filter=mobile",
    "build": "turbo run build",
    "build:web": "turbo run build --filter=web",
    "start:web": "turbo run start --filter=web",
    "prod:web": "turbo run build --filter=web && turbo run start --filter=web",
    "lint": "turbo run lint",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "turbo": "^2.3.3"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "19.1.0",
      "@types/react-dom": "19.1.0",
      "react-dom": "19.1.0"
    }
  },
  "packageManager": "pnpm@9.15.1",
  "lint-staged": {
    "apps/web/**/*.{js,jsx,ts,tsx}": [
      "eslint --fix"
    ],
    "apps/admin/**/*.{js,jsx,ts,tsx}": [
      "eslint --fix"
    ]
  }
}
