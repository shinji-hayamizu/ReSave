{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "skipLibCheck": true,
    "paths": {
      "@/*": [
        "./*"
      ],
      "@resave/shared": [
        "../../packages/shared/src/index.ts"
      ],
      "@resave/shared/types": [
        "../../packages/shared/src/types/index.ts"
      ],
      "@resave/shared/validations": [
        "../../packages/shared/src/validations/index.ts"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts",
    "nativewind-env.d.ts"
  ]
}